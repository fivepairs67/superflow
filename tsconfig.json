{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["chrome", "react", "react-dom"],
    "skipLibCheck": true,
    "useDefineForClassFields": true
  },
  "include": ["extension/src/**/*.ts", "extension/src/**/*.tsx", "tools/build/**/*.mjs"]
}
