{
  "manifest_version": 3,
  "name": "SuperFLOW",
  "description": "SQL flow and lineage visualizer for web-based SQL editors. Best experienced in Superset SQL Lab.",
  "version": "0.1.1",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["sidePanel", "storage", "tabs", "scripting", "clipboardRead"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "SuperFLOW",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
